{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install git+https://github.com/LonamiWebs/Telethon.git && pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "python bot.py",
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 10
  }
}